{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holdencapital.io/schemas/refactor-finding.schema.json",
  "title": "Refactor Opportunity Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "finding_id",
    "job_id",
    "category",
    "title",
    "file_path",
    "line_start",
    "line_end",
    "evidence",
    "suggested_refactor",
    "estimated_effort",
    "impact_score",
    "confidence",
    "risk_level",
    "requires_human_review"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "finding_id": {
      "type": "string",
      "minLength": 1
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "duplication",
        "complexity",
        "dead_code",
        "naming",
        "architecture",
        "maintainability"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "file_path": {
      "type": "string",
      "minLength": 1
    },
    "line_start": {
      "type": "integer",
      "minimum": 1
    },
    "line_end": {
      "type": "integer",
      "minimum": 1
    },
    "evidence": {
      "type": "string",
      "minLength": 1
    },
    "suggested_refactor": {
      "type": "string",
      "minLength": 1
    },
    "estimated_effort": {
      "type": "string",
      "enum": [
        "S",
        "M",
        "L"
      ]
    },
    "impact_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "requires_human_review": {
      "type": "boolean"
    }
  }
}
