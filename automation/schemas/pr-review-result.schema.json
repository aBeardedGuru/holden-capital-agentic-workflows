{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holdencapital.io/schemas/pr-review-result.schema.json",
  "title": "PR Review Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "repo",
    "pr_number",
    "pr_url",
    "pr_head_sha",
    "review_role",
    "verdict",
    "overall_severity",
    "summary",
    "findings",
    "checks_ran",
    "requires_follow_up",
    "comment_markdown"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "repo": {
      "type": "string",
      "pattern": "^[^\\s/]+/[^\\s/]+$"
    },
    "pr_number": {
      "type": "integer",
      "minimum": 1
    },
    "pr_url": {
      "type": "string",
      "minLength": 1
    },
    "pr_head_sha": {
      "type": [
        "string",
        "null"
      ]
    },
    "review_role": {
      "type": "string",
      "enum": [
        "ci_cd",
        "security",
        "tests",
        "architecture",
        "docs"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "approve",
        "comment",
        "request_changes",
        "informational"
      ]
    },
    "overall_severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "severity",
          "category",
          "file_path",
          "line",
          "rationale",
          "recommendation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "file_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "line": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "checks_ran": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires_follow_up": {
      "type": "boolean"
    },
    "comment_markdown": {
      "type": "string"
    }
  }
}
