{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holdencapital.io/schemas/pr-review-job.schema.json",
  "title": "Periodic PR Review Job",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "repo",
    "pr_number",
    "pr_title",
    "pr_url",
    "pr_head_sha",
    "pr_base_ref",
    "pr_head_ref",
    "labels",
    "changed_files",
    "review_role"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "repo": {
      "type": "string",
      "pattern": "^[^\\s/]+/[^\\s/]+$"
    },
    "pr_number": {
      "type": "integer",
      "minimum": 1
    },
    "pr_title": {
      "type": "string",
      "minLength": 1
    },
    "pr_url": {
      "type": "string",
      "minLength": 1
    },
    "pr_head_sha": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 7
    },
    "pr_base_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "pr_head_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_role": {
      "type": "string",
      "enum": [
        "ci_cd",
        "security",
        "tests",
        "architecture",
        "docs"
      ]
    }
  }
}
