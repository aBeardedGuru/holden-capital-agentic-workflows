N8N_BASE_URL=https://n8n.holdencapital.io/
N8N_API_KEY=replace_me
N8N_TRIGGER_ENDPOINT=/webhook/finance-invoices-trigger
N8N_ENV_FILE=/run/holden-config/n8n.env
N8N_TLS_VERIFY=true
# Optional: set for self-signed/private CA deployments
# N8N_CA_BUNDLE=/run/holden-config/n8n-ca.pem
GOOGLE_SERVICE_ACCOUNT_FILE=/run/holden-config/google-service-account.json
GOOGLE_SHEETS_LEDGER_ID=HOLDEN_FINANCE_LEDGER_SPREADSHEET_ID
HOLDEN_FINANCE_INVOICES_INBOX_FOLDER_ID=...
HOLDEN_FINANCE_INVOICES_PROCESSING_FOLDER_ID=...
HOLDEN_FINANCE_INVOICES_PROCESSED_FOLDER_ID=...
HOLDEN_FINANCE_INVOICES_REVIEW_FOLDER_ID=...
HOLDEN_FINANCE_INVOICES_ERROR_FOLDER_ID=...
AUDIT_LOG_SHEET_NAME=Dashboard Audit Log
MAX_UPLOAD_MB=20
MAX_BATCH_FILES=25
POLL_INTERVAL_SEC=5
REQUEST_TIMEOUT_SEC=30
RUNTIME_AUDIT_LOG_PATH=/app/runtime/audit-log.jsonl
